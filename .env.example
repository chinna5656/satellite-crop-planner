# Runtime
CROP_API_ENVIRONMENT=production
CROP_API_APP_VERSION=1.0.0
CROP_API_DOCS_ENABLED=false
CROP_API_SERVE_FRONTEND=true

# Security
# Use JSON list syntax for list settings.
CROP_API_CORS_ORIGINS=["https://your-domain.example"]
CROP_API_ALLOWED_HOSTS=["your-domain.example","127.0.0.1"]

# Analysis limits
CROP_API_MAX_CLOUD_COVER=10
CROP_API_RELAXED_MAX_CLOUD_COVER=80
CROP_API_MAX_RESPONSE_PIXELS=15000
CROP_API_DEFAULT_RAINFALL_MM_15D=0

# STAC
CROP_API_PLANETARY_COMPUTER_STAC_URL=https://planetarycomputer.microsoft.com/api/stac/v1
